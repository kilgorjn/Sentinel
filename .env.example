# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Ollama inference server
OLLAMA_URL=http://jeffs-gaming-pc.lan:11434
OLLAMA_MODEL=gemma3:12b

# NewsAPI key — get one free at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Display timezone for the frontend (IANA timezone name)
DISPLAY_TIMEZONE=America/New_York

# MySQL database configuration
# For Docker: mysql+pymysql://user:password@mysql:3306/sentinel
# For local dev: mysql+pymysql://user:password@localhost:3306/sentinel
DATABASE_URL=mysql+pymysql://sentinel:sentinel@localhost:3306/sentinel
MYSQL_ROOT_PASSWORD=root
MYSQL_PASSWORD=sentinel

# JSON log file path (shipped to Splunk)
SENTINEL_LOG_PATH=/data/financial_news.log

# Path to legacy SQLite database for one-time migration to MySQL.
# Set this when migrating existing data (typically the old Docker volume path).
# Migration runs once on monitor startup, then sets a completion flag.
SENTINEL_DB_PATH=/data/news_events.db

# Optional: Slack incoming webhook URL for surge alerts
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
